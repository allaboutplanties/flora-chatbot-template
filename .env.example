# ─── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASE_URL=https://flow.allaboutplanties.com
N8N_WEBHOOK_CHAT=/webhook/flora-chat
N8N_WEBHOOK_IMAGE=/webhook/flora-image
N8N_WEBHOOK_LIGHT=/webhook/flora-light

# ─── Security Gate ────────────────────────────────────────────────────────────
FLORA_HMAC_SECRET=<generate-32-random-chars>
FLORA_ALLOWED_ORIGINS=https://allaboutplanties.com,https://allaboutplanties.myshopify.com
FLORA_RATE_LIMIT_MESSAGES=20
FLORA_RATE_LIMIT_WINDOW_HOURS=1
FLORA_TOKEN_EXPIRY_HOURS=2
FLORA_MAX_IMAGE_SIZE_MB=2
FLORA_MAX_MESSAGE_LENGTH=1000

# ─── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=allaboutplanties.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=<storefront-api-token>
SHOPIFY_ADMIN_TOKEN=<admin-api-token>

# ─── External Plant APIs ──────────────────────────────────────────────────────
PERENUAL_API_KEY=<perenual-key>
PLANTNET_API_KEY=<plantnet-key>

# ─── Feature Flags ────────────────────────────────────────────────────────────
FLORA_ENABLE_VISION=true
FLORA_ENABLE_LIGHT_METER=true
FLORA_ENABLE_ORDERS=true
FLORA_ENABLE_SEASONAL=true
FLORA_CACHE_TTL_DAYS=30
