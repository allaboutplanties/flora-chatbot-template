{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Theme",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "emoji": { "type": "string" },
    "dateRange": {
      "type": "object",
      "properties": {
        "start": { "type": "string", "pattern": "^\\d{2}-\\d{2}$" },
        "end": { "type": "string", "pattern": "^\\d{2}-\\d{2}$" }
      }
    },
    "overrides": {
      "type": "object",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "accent": { "type": "string" }
          }
        },
        "avatar": {
          "type": "object",
          "properties": {
            "url": { "type": "string" },
            "fallback": { "type": "string" }
          }
        },
        "messages": {
          "type": "object",
          "properties": {
            "welcome": {
              "type": "object",
              "properties": {
                "en": { "type": "string" },
                "es": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
